{
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.clj": "${capture}.clj.d.ts"
  },
  "calva.replConnectSequences": [
    {
      "name": "cljam nREPL",
      "projectType": "generic",
      "nReplPortFile": [
        ".nrepl-port"
      ],
      "afterPrimaryReplConnectedCode": "(println \"Connected to cljam nREPL\")",
      "customJackInCommandLine": "cljam nrepl-server",
    },
    {
      "name": "cljam nodejs interop",
      "projectType": "custom",
      "cljsType": "none",
      "nReplPortFile": [
        ".nrepl-port"
      ],
      "afterPrimaryReplConnectedCode": "(println \"Connected to cljam nREPL\")",
      "customJackInCommandLine": "npm run start",
    },
    {
      "name": "cljam mcp workspace",
      "projectType": "custom",
      "cljsType": "none",
      "nReplPortFile": [
        ".nrepl-port"
      ],
      "afterPrimaryReplConnectedCode": "(println \"Connected to cljam mcp workspace\")",
      "customJackInCommandLine": "npm run jack-in",
    }
  ],
  "calva.outputDestinations": {
    "evalResults": "repl-window",
    "evalOutput": "repl-window",
    "otherOutput": "repl-window"
  },
  "calva.showCalvaSaysOnConnect": false
}